# Copy to config.toml in the project root (or ~/.config/security-now-dashboard/config.toml)

[downloads]
dir = "./downloads"
parallel = 2
skip_existing = true
# raw | ordered | kodi
filename_format = "raw"
min_free_mb = 500
verify_ssl = true

[media]
default = ["audio_hq"]

[history]
# file = "./downloads/.sn-history.jsonl"

# CLI / cron (also available as SN_* env vars):
# SN_EPISODES=next
# SN_MEDIA=audio_hq,show_notes
# SN_QUIET=1
# SN_JSON=0
# SN_PRETEND=0

[rss]
# dir = "./downloads"
# base_url = "https://sn.example.com"
limit = 500

[search]
# db = "./downloads/.sn-search.db"

[security]
# auth_user = "admin"
# auth_password = "change-me"
# api_key = "your-automation-key"
dev_mode = true
# rate_limit_per_minute = 30
# cors_origins = ["https://sn.example.com"]

[watcher]
enabled = false
interval_hours = 6
# notifier_webhook = "https://notifier.example/hooks/..."
# discord_webhook = "https://discord.com/api/webhooks/..."
# telegram_bot_token = "123456:ABC..."
# telegram_chat_id = "987654321"
# telegram_on_job_complete = true
# heartbeat_interval_hours = 6

[ops]
log_json = false
log_level = "INFO"
part_cleanup_days = 7
# require_download_lock = true