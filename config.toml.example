# Copy to config.toml in the project root (or ~/.config/security-now-dashboard/config.toml)

[downloads]
dir = "./downloads"
parallel = 2
skip_existing = true
# raw | ordered | kodi
filename_format = "raw"
min_free_mb = 500
verify_ssl = true

[media]
default = ["audio_hq"]

[history]
# file = "./downloads/.sn-history.jsonl"

# CLI / cron (also available as SN_* env vars):
# SN_EPISODES=next
# SN_MEDIA=audio_hq,show_notes
# SN_QUIET=1
# SN_JSON=0
# SN_PRETEND=0

[rss]
# dir = "./downloads"
# base_url = "https://sn.example.com"
limit = 500

[search]
# db = "./downloads/.sn-search.db"